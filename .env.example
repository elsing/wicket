# Copy this to .env and fill in your values
# NEVER commit .env to version control

# Generate WireGuard private key:
#   wg genkey
WICKET_WG_PRIVATE_KEY=

# From Authentik: Applications > your app > Edit > OAuth2/OIDC Provider
WICKET_OIDC_CLIENT_ID=
WICKET_OIDC_CLIENT_SECRET=

# Generate with: openssl rand -hex 32
WICKET_PUBLIC_SESSION_SECRET=
WICKET_ADMIN_HMAC_SECRET=
WICKET_ADMIN_SESSION_SECRET=

# SMTP password (optional — only needed if smtp.enabled: true)
WICKET_SMTP_PASSWORD=
